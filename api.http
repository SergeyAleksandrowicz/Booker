### Variables
@baseUrl = http://localhost:3000/api
@token = your_access_token_here
@refreshToken = your_refresh_token_here

###############################################################################
# AUTHENTICATION ENDPOINTS
###############################################################################

### Register a new user
POST {{baseUrl}}/api/auth/register
Content-Type: application/json

{
  "email": "testuser@example.com",
  "password": "Password123!",
  "passwordConfirm": "Password123!"
}

### Login
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "testuser@example.com",
  "password": "Password123!"
}

### Refresh Token
POST {{baseUrl}}/api/auth/refresh
Content-Type: application/json

{
  "refreshToken": "{{refreshToken}}"
}

### Get Profile (Protected - requires token)
GET {{baseUrl}}/api/protected/profile
Authorization: Bearer {{token}}

###############################################################################
# PUBLIC SERVICE ENDPOINTS (No Authentication Required)
###############################################################################

### List all active services
GET {{baseUrl}}/api/services

### Get specific service
GET {{baseUrl}}/api/services/1

### Get availability slots for a service
GET {{baseUrl}}/api/services/1/availability

### Get availability slots with from date filter
GET {{baseUrl}}/api/services/1/availability?fromDate=2024-01-15

### Get availability by date range
GET {{baseUrl}}/api/services/1/availability/dates/2024-01-15/2024-01-20

###############################################################################
# BOOKING ENDPOINTS (Requires Authentication)
###############################################################################

### Create a new booking
POST {{baseUrl}}/api/bookings
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "availabilityId": 7,
  "notes": "Looking forward to this appointment!"
}

### Get all bookings for current user
GET {{baseUrl}}/api/bookings
Authorization: Bearer {{token}}

### Get specific booking details
GET {{baseUrl}}/api/bookings/1
Authorization: Bearer {{token}}

### Update booking status to confirmed
PATCH {{baseUrl}}/api/bookings/1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "status": "confirmed"
}

### Update booking notes
PATCH {{baseUrl}}/api/bookings/1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "notes": "Updated notes about my booking"
}

### Mark booking as completed
PATCH {{baseUrl}}/api/bookings/1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "status": "completed"
}

### Cancel a booking
DELETE {{baseUrl}}/api/bookings/1
Authorization: Bearer {{token}}